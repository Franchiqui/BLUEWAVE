# Environment Variables
# Copy this file to .env.local and fill in your values

# Application
NEXT_PUBLIC_APP_NAME=Zeus IA
NEXT_PUBLIC_APP_URL=http://localhost:8741

# PocketBase (auth)
NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Database (if needed)
# DATABASE_URL=

# Authentication (if needed)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:8741

# API Keys (if needed)
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=

# Asistente Zeus IA (chat de la home) — solo servidor, no exponer al navegador
# URL pública del túnel al RAE API (api/api-rae, puerto 3011) de la app Zeus IA
ZEUS_PIPELINE_URL=https://rae.zeus-ia.com
# Endpoint compatible OpenAI del modelo servido en el NAS vía túnel fijo
ZEUS_PIPELINE_MODEL_URL=https://<tunnel-nas>/v1/chat/completions
ZEUS_PIPELINE_MODEL_NAME=
ZEUS_PIPELINE_MODEL_KEY=

# Next.js specific
NEXT_PUBLIC_VERCEL_URL=
ANALYZE=false